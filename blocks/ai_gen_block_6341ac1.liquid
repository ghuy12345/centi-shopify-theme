{% doc %}
  @prompt
    can we add a collection grid with clickable images with text saying which collection it is at the bottom left of the image. make it 4 collection images, can we be able to edit the collection name text? also can we make the photos larger so it all fits in? photos need to be taller please to fit the entire images in. also dont make the images curved. we also need to make sure that the text on the bottom left fits on the image and the space inbetween each image is the same., we need to use the luxury font weve been using across the whole site with no black border, text only., can we leave some spacing at the bottom as it's too close to the section below.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-collection-grid-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding-bottom: {{ block.settings.bottom_spacing }}px;
  }

  .ai-collection-grid-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    width: 100%;
  }

  .ai-collection-grid-item-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    display: block;
    text-decoration: none;
  }

  .ai-collection-grid-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .ai-collection-grid-item-{{ ai_gen_id }}:hover .ai-collection-grid-image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-collection-grid-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-collection-grid-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-collection-grid-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.text_padding }}px;
    left: {{ block.settings.text_padding }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    font-family: {{ block.settings.text_font.family }}, {{ block.settings.text_font.fallback_families }};
    font-style: {{ block.settings.text_font.style }};
    letter-spacing: {{ block.settings.letter_spacing }}em;
    text-transform: {{ block.settings.text_transform }};
    z-index: 2;
    pointer-events: none;
    text-shadow: {{ block.settings.text_shadow_x }}px {{ block.settings.text_shadow_y }}px {{ block.settings.text_shadow_blur }}px {{ block.settings.text_shadow_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-collection-grid-container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-collection-grid-text-overlay-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-collection-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-collection-grid-container-{{ ai_gen_id }}">
    {% for i in (1..4) %}
      {% liquid
        assign collection_key = 'collection_' | append: i
        assign text_key = 'collection_text_' | append: i
        assign collection = block.settings[collection_key]
        assign collection_text = block.settings[text_key]
      %}

      {% if collection != blank %}
        <a href="{{ collection.url }}" class="ai-collection-grid-item-{{ ai_gen_id }}">
          {% if collection.featured_image %}
            <img
              src="{{ collection.featured_image | image_url: width: 800 }}"
              alt="{{ collection.featured_image.alt | escape }}"
              loading="lazy"
              width="800"
              height="{{ 800 | divided_by: block.settings.image_aspect_ratio | round }}"
              class="ai-collection-grid-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-collection-grid-placeholder-{{ ai_gen_id }}">
              {{ 'collection-1' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if collection_text != blank %}
            <div class="ai-collection-grid-text-overlay-{{ ai_gen_id }}">
              {{ collection_text }}
            </div>
          {% endif %}
        </a>
      {% else %}
        <div class="ai-collection-grid-item-{{ ai_gen_id }}">
          <div class="ai-collection-grid-placeholder-{{ ai_gen_id }}">
            {{ 'collection-1' | placeholder_svg_tag }}
          </div>
          <div class="ai-collection-grid-text-overlay-{{ ai_gen_id }}">
            Collection {{ i }}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

