    {
      "type": "range",
      "id": "nav_size",
      "label": "Arrow circle size",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "nav_offset",
      "label": "Arrow offset from edge",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "nav_opacity",
      "label": "Arrow opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.9
    },
    {
      "type": "color",
      "id": "nav_bg_color",
      "label": "Arrow background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_hover_bg_color",
      "label": "Arrow hover background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_icon_color",
      "label": "Arrow icon color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "nav_hover_icon_color",
      "label": "Arrow hover icon color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Dots navigation"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
