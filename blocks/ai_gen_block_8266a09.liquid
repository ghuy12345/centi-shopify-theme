"settings":[

{
"type":"header",
"content":"Collection 1"
},
{
"type":"collection",
"id":"collection_1",
"label":"Collection"
},
{
"type":"text",
"id":"custom_title_1",
"label":"Custom title"
},

{
"type":"header",
"content":"Collection 2"
},
{
"type":"collection",
"id":"collection_2",
"label":"Collection"
},
{
"type":"text",
"id":"custom_title_2",
"label":"Custom title"
},

{
"type":"header",
"content":"Collection 3"
},
{
"type":"collection",
"id":"collection_3",
"label":"Collection"
},
{
"type":"text",
"id":"custom_title_3",
"label":"Custom title"
},

{
"type":"header",
"content":"Collection 4"
},
{
"type":"collection",
"id":"collection_4",
"label":"Collection"
},
{
"type":"text",
"id":"custom_title_4",
