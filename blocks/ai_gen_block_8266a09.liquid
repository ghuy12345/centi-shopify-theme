{% doc %}
  @prompt
    can we add a collection grid with clickable images with text saying which collection it is at the bottom left of the image. make it 3 collection images, can we be able to edit the collection name text? also can we make the photos larger so it all fits in? can we have 4 collections instead of 3, photos need to be taller please to fit the entire images in
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
.ai-collection-grid-{{ ai_gen_id }}{
display:block;
width:{{ block.settings.desktop_width_percent }}%;
max-width:100%;
}

.ai-collection-grid__container-{{ ai_gen_id }}{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:{{ block.settings.grid_gap }}px;
}

.ai-collection-grid__item-{{ ai_gen_id }}{
position:relative;
overflow:hidden;
border-radius:{{ block.settings.border_radius }}px;
aspect-ratio:{{ block.settings.image_aspect_ratio }};
background:{{ block.settings.card_bg }};
}

.ai-collection-grid__link-{{ ai_gen_id }}{
display:block;
width:100%;
height:100%;
position:relative;
text-decoration:none;
}

.ai-collection-grid__image-{{ ai_gen_id }}{
width:100%;
height:100%;
object-fit:{{ block.settings.image_fit }};
object-position:center;
transition:transform {{ block.settings.hover_animation_duration }}s ease;
display:block;
}

.ai-collection-grid__link-{{ ai_gen_id }}:hover .ai-collection-grid__image-{{ ai_gen_id }}{
transform:scale({{ block.settings.hover_scale }});
}

.ai-collection-grid__placeholder-{{ ai_gen_id }}{
width:100%;
height:100%;
background:#f4f4f4;
display:flex;
align-items:center;
justify-content:center;
position:relative;
}

.ai-collection-grid__empty-state-{{ ai_gen_id }}{
position:absolute;
bottom:20px;
left:50%;
transform:translateX(-50%);
padding:8px 16px;
font-size:12px;
color:#666;
text-align:center;
pointer-events:none;
background:rgba(255,255,255,0.9);
border-radius:4px;
}

.ai-collection-grid__overlay-{{ ai_gen_id }}{
position:absolute;
inset:0;
background:linear-gradient(
to bottom,
rgba(0,0,0,0)0%,
rgba(0,0,0,{{ block.settings.overlay_opacity }})100%
);
pointer-events:none;
}

.ai-collection-grid__title-{{ ai_gen_id }}{
position:absolute;
bottom:{{ block.settings.text_padding }}px;
left:{{ block.settings.text_padding }}px;
color:{{ block.settings.text_color }};
font-size:{{ block.settings.text_size }}px;
font-weight:{{ block.settings.text_weight }};
margin:0;
z-index:2;
text-shadow:0 2px 4px rgba(0,0,0,0.35);
line-height:1.1;
}

@media screen and (max-width:749px){

.ai-collection-grid__container-{{ ai_gen_id }}{
grid-template-columns:repeat({{ block.settings.mobile_columns }},1fr);
gap:{{ block.settings.mobile_grid_gap }}px;
}

.ai-collection-grid__title-{{ ai_gen_id }}{
font-size:{{ block.settings.mobile_text_size }}px;
bottom:{{ block.settings.mobile_text_padding }}px;
left:{{ block.settings.mobile_text_padding }}px;
}

}
{% endstyle %}

<div class="ai-collection-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
<div class="ai-collection-grid__container-{{ ai_gen_id }}">

{% for i in (1..4) %}

{% liquid
assign collection_key='collection_'|append:i
assign custom_title_key='custom_title_'|append:i
assign collection=block.settings[collection_key]
assign custom_title=block.settings[custom_title_key]
%}

<div class="ai-collection-grid__item-{{ ai_gen_id }}">

{% if collection != blank %}

<a href="{{ collection.url }}" class="ai-collection-grid__link-{{ ai_gen_id }}">

{% if collection.featured_image %}

<img
src="{{ collection.featured_image | image_url: width: 1600 }}"
alt="{{ collection.featured_image.alt | escape }}"
loading="lazy"
width="{{ collection.featured_image.width }}"
height="{{ collection.featured_image.height }}"
class="ai-collection-grid__image-{{ ai_gen_id }}"
>

{% else %}

<div class="ai-collection-grid__placeholder-{{ ai_gen_id }}">
{{ 'collection-1' | placeholder_svg_tag }}
</div>

{% endif %}

<div class="ai-collection-grid__overlay-{{ ai_gen_id }}"></div>

<h3 class="ai-collection-grid__title-{{ ai_gen_id }}">

{% if custom_title != blank %}
{{ custom_title }}
{% else %}
{{ collection.title }}
{% endif %}

</h3>

</a>

{% else %}

<div class="ai-collection-grid__link-{{ ai_gen_id }}">

<div class="ai-collection-grid__placeholder-{{ ai_gen_id }}">

{{ 'collection-1' | placeholder_svg_tag }}

<div class="ai-collection-grid__empty-state-{{ ai_gen_id }}">
Select collection {{ i }}
</div>

</div>

<div class="ai-collection-grid__overlay-{{ ai_gen_id }}"></div>

<h3 class="ai-collection-grid__title-{{ ai_gen_id }}">

{% if custom_title != blank %}
{{ custom_title }}
{% else %}
Collection {{ i }}
{% endif %}

</h3>

</div>

{% endif %}

</div>

{% endfor %}

</div>
</div>

