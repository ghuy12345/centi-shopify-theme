{% doc %}
  @prompt
    can we get an image banner and make it so that it's a different image for desktop than it is mobile, can we change it so we can "adapt to first image" WITH DESKTOP
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-banner-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-image-banner-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-image-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  {% if block.settings.desktop_height == 'adapt' %}
    .ai-image-banner-desktop-{{ ai_gen_id }} .ai-image-banner-image-{{ ai_gen_id }} {
      object-fit: contain;
    }
  {% else %}
    .ai-image-banner-desktop-{{ ai_gen_id }} {
      height: {{ block.settings.desktop_height }}px;
    }

    .ai-image-banner-desktop-{{ ai_gen_id }} .ai-image-banner-image-{{ ai_gen_id }} {
      height: 100%;
      object-fit: cover;
    }
  {% endif %}

  .ai-image-banner-desktop-{{ ai_gen_id }} {
    display: block;
  }

  .ai-image-banner-mobile-{{ ai_gen_id }} {
    display: none;
  }

  .ai-image-banner-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-image-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-image-banner-desktop-{{ ai_gen_id }} {
      display: none;
    }

    .ai-image-banner-mobile-{{ ai_gen_id }} {
      display: block;
    }

    .ai-image-banner-placeholder-{{ ai_gen_id }} {
      min-height: 300px;
    }
  }
{% endstyle %}

<div class="ai-image-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-banner-wrapper-{{ ai_gen_id }}">
    {% if block.settings.desktop_image or block.settings.mobile_image %}
      <div class="ai-image-banner-desktop-{{ ai_gen_id }}">
        {% if block.settings.desktop_image %}
          <img
            src="{{ block.settings.desktop_image | image_url: width: 2000 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
            class="ai-image-banner-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-banner-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-image-banner-empty-state-{{ ai_gen_id }}">
              Add a desktop image
            </div>
          </div>
        {% endif %}
      </div>

      <div class="ai-image-banner-mobile-{{ ai_gen_id }}">
        {% if block.settings.mobile_image %}
          <img
            src="{{ block.settings.mobile_image | image_url: width: 1000 }}"
            alt="{{ block.settings.mobile_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.mobile_image.width }}"
            height="{{ block.settings.mobile_image.height }}"
            class="ai-image-banner-image-{{ ai_gen_id }}"
          >
        {% elsif block.settings.desktop_image %}
          <img
            src="{{ block.settings.desktop_image | image_url: width: 1000 }}"
            alt="{{ block.settings.desktop_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.desktop_image.width }}"
            height="{{ block.settings.desktop_image.height }}"
            class="ai-image-banner-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-banner-placeholder-{{ ai_gen_id }}">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
            <div class="ai-image-banner-empty-state-{{ ai_gen_id }}">
              Add a mobile image
            </div>
          </div>
        {% endif %}
      </div>
    {% else %}
      <div class="ai-image-banner-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-image-banner-empty-state-{{ ai_gen_id }}">
          Add desktop and mobile images
        </div>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Image banner",
  "settings": [
    {
      "type": "header",
      "content": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Desktop height",
      "options": [
        {
          "value": "adapt",
          "label": "Adapt to first image"
        },
        {
          "value": "400",
          "label": "Small"
        },
        {
          "value": "550",
          "label": "Medium"
        },
        {
          "value": "750",
          "label": "Large"
        }
      ],
      "default": "adapt"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "paragraph",
      "content": "If no mobile image is selected, the desktop image will be used on mobile devices."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ]
}
{% endschema %}
