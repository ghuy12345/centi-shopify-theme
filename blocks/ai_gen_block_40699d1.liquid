{% doc %}
  @prompt
    Create a homepage section called "Product Banner."
    
    Add an image picker.
    Show the image full-width across the page.
    Make the whole image a clickable link to a product (add a link field).
    Add top and bottom padding settings.
{% enddoc %}
{% style %}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  
  .product-banner-{{ section.id }} {
    width: 100%;
    display: block;
  }
  
  .product-banner-{{ section.id }} img {
    width: 100%;
    height: auto;
    display: block;
  }
{% endstyle %}

<div class="product-banner-wrapper">
  {% if section.settings.product_link != blank %}
    <a href="{{ section.settings.product_link }}" class="product-banner-{{ section.id }}">
      {% if section.settings.banner_image != blank %}
        {{ section.settings.banner_image | image_url: width: 2000 | image_tag: loading: 'lazy', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000' }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </a>
  {% else %}
    <div class="product-banner-{{ section.id }}">
      {% if section.settings.banner_image != blank %}
        {{ section.settings.banner_image | image_url: width: 2000 | image_tag: loading: 'lazy', widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000' }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Product Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "url",
      "id": "product_link",
      "label": "Product Link",
      "info": "Link to a product page"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Product Banner"
    }
  ]
}
{% endschema %}