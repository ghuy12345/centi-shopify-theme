{%- style -%}
  .section-product-banner-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .section-product-banner-{{ section.id }} a,
  .section-product-banner-{{ section.id }} .product-banner__inner {
    display: block;
    width: 100%;
    line-height: 0;
  }
  .section-product-banner-{{ section.id }} img {
    display: block;
    width: 100%;
    height: auto;
  }
{%- endstyle -%}

<div class="section-product-banner-{{ section.id }}">
  {%- if section.settings.banner_link != blank -%}
    <a href="{{ section.settings.banner_link }}">
  {%- endif -%}

    {%- if section.settings.banner_image != blank -%}
      <img
        src="{{ section.settings.banner_image | image_url: width: 1500 }}"
        alt="{{ section.settings.banner_image.alt | escape }}"
        loading="lazy">
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}

  {%- if section.settings.banner_link != blank -%}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Product Banner",
  "tag": "section",
  "class": "section-product-banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "url",
      "id": "banner_link",
      "label": "Link to Product"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Product Banner"
    }
  ]
}
{% endschema %}