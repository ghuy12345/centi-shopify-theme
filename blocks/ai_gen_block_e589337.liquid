                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}

      {% if block.settings.menu_3 != blank %}
        <div class="ai-luxury-footer-column-{{ ai_gen_id }}">
          <button
            class="ai-luxury-footer-accordion-trigger-{{ ai_gen_id }}"
            aria-expanded="false"
            data-accordion-trigger
          >
            <h3 class="ai-luxury-footer-column-heading-{{ ai_gen_id }}">{{ block.settings.menu_3_heading }}</h3>
            <svg class="ai-luxury-footer-accordion-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="ai-luxury-footer-links-wrapper-{{ ai_gen_id }}">
            <h3 class="ai-luxury-footer-column-heading-{{ ai_gen_id }} ai-luxury-footer-desktop-heading-{{ ai_gen_id }}">{{ block.settings.menu_3_heading }}</h3>
            <ul class="ai-luxury-footer-links-{{ ai_gen_id }}" data-accordion-content>
              {% for link in linklists[block.settings.menu_3].links %}
                <li class="ai-luxury-footer-link-item-{{ ai_gen_id }}">
                  <a href="{{ link.url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}

      {% if block.settings.menu_4 != blank %}
        <div class="ai-luxury-footer-column-{{ ai_gen_id }}">
          <button
            class="ai-luxury-footer-accordion-trigger-{{ ai_gen_id }}"
            aria-expanded="false"
            data-accordion-trigger
          >
            <h3 class="ai-luxury-footer-column-heading-{{ ai_gen_id }}">{{ block.settings.menu_4_heading }}</h3>
            <svg class="ai-luxury-footer-accordion-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="ai-luxury-footer-links-wrapper-{{ ai_gen_id }}">
            <h3 class="ai-luxury-footer-column-heading-{{ ai_gen_id }} ai-luxury-footer-desktop-heading-{{ ai_gen_id }}">{{ block.settings.menu_4_heading }}</h3>
            <ul class="ai-luxury-footer-links-{{ ai_gen_id }}" data-accordion-content>
              {% for link in linklists[block.settings.menu_4].links %}
                <li class="ai-luxury-footer-link-item-{{ ai_gen_id }}">
                  <a href="{{ link.url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.show_social_icons %}
      <div class="ai-luxury-footer-social-{{ ai_gen_id }}">
