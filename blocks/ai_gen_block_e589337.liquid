{% doc %}
  @prompt
    Create a minimal, luxury FOOTER section for a high-end women's fashion brand,
    inspired by arakii.com — clean, lots of whitespace, understated. Do NOT include an
    email/newsletter signup in this footer (we have a separate section for that).
    
    CONTENT
    - Brand name or logo at the top (let me choose: upload a logo image OR use text).
    - Link columns driven by Shopify navigation menus (linklists) so I can edit them in
      the admin. I want up to 3–4 columns, each with its own heading (e.g. "Shop",
      "Help", "About", "Legal") and a menu of links underneath.
    - Social media icons (Instagram, TikTok, etc.) pulled from the theme's existing
      social link settings.
    - A bottom bar with: copyright line (auto year + shop name) and optional small
      payment icons.
    - Optional country/currency selector if the store has multiple markets.
    
    STYLE
    - Minimal, neutral, luxury. Use the theme's existing fonts and colors.
    - Generous spacing/padding, thin divider lines if needed, small uppercase column
      headings with light letter-spacing.
    
    RESPONSIVE / MOBILE-FIRST (90% of shoppers are on mobile)
    - On mobile, the link columns should stack cleanly (or collapse into tidy tap-to-
      expand accordions), social icons centered or left-aligned, copyright at the bottom.
    
    EDITOR SETTINGS I WANT
    - Logo image OR brand text + logo size.
    - 3–4 link columns: each = a heading + a menu (linklist) picker.
    - Show social icons on/off.
    - Show payment icons on/off.
    - Show country/currency selector on/off.
    - Copyright text.
    - Background color, text color, section top & bottom padding., this is a bit of a mess, remove all the payment section as it doesn't look good, need to add the policies at the bottom
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-luxury-footer-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    width: 100%;
    display: block;
  }

  .ai-luxury-footer-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-luxury-footer-brand-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .ai-luxury-footer-logo-{{ ai_gen_id }} {
    max-width: {{ block.settings.logo_width }}px;
    height: auto;
    display: inline-block;
  }

  .ai-luxury-footer-brand-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.logo_width | divided_by: 4 }}px;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  .ai-luxury-footer-nav-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 40px;
    margin-bottom: 60px;
    padding-bottom: 60px;
    border-bottom: 1px solid {{ block.settings.text_color | color_modify: 'alpha', 0.15 }};
  }

  .ai-luxury-footer-column-{{ ai_gen_id }} {
    text-align: left;
  }

  .ai-luxury-footer-column-heading-{{ ai_gen_id }} {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin: 0 0 20px 0;
    opacity: 0.6;
  }

  .ai-luxury-footer-links-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-luxury-footer-link-item-{{ ai_gen_id }} {
    margin-bottom: 12px;
  }

  .ai-luxury-footer-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: 14px;
    font-weight: 300;
    transition: opacity 0.2s ease;
    display: inline-block;
  }

  .ai-luxury-footer-link-{{ ai_gen_id }}:hover {
    opacity: 0.6;
  }

  .ai-luxury-footer-social-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 50px;
  }

  .ai-luxury-footer-social-list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: 24px;
    flex-wrap: wrap;
  }

  .ai-luxury-footer-social-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: 20px;
    transition: opacity 0.2s ease;
    display: inline-block;
  }

  .ai-luxury-footer-social-link-{{ ai_gen_id }}:hover {
    opacity: 0.6;
  }

  .ai-luxury-footer-social-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    display: block;
  }

  .ai-luxury-footer-bottom-{{ ai_gen_id }} {
    text-align: center;
    padding-top: 30px;
  }

  .ai-luxury-footer-copyright-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 300;
    opacity: 0.6;
    margin-bottom: 20px;
  }

  .ai-luxury-footer-policies-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .ai-luxury-footer-policy-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }

  .ai-luxury-footer-policy-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-luxury-footer-accordion-trigger-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-footer-brand-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }

    .ai-luxury-footer-nav-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 0;
      margin-bottom: 40px;
      padding-bottom: 40px;
      border-bottom: 1px solid {{ block.settings.text_color | color_modify: 'alpha', 0.1 }};
    }

    .ai-luxury-footer-column-{{ ai_gen_id }} {
      border-bottom: 1px solid {{ block.settings.text_color | color_modify: 'alpha', 0.1 }};
    }

    .ai-luxury-footer-accordion-trigger-{{ ai_gen_id }} {
      display: flex;
      justify-content: space-between;
      align-items: center;
      width: 100%;
      background: none;
      border: none;
      padding: 20px 0;
      cursor: pointer;
      text-align: left;
      color: {{ block.settings.text_color }};
    }

    .ai-luxury-footer-column-heading-{{ ai_gen_id }} {
      margin: 0;
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      opacity: 0.8;
    }

    .ai-luxury-footer-accordion-icon-{{ ai_gen_id }} {
      width: 12px;
      height: 12px;
      transition: transform 0.3s ease;
    }

    .ai-luxury-footer-accordion-icon-{{ ai_gen_id }}.active {
      transform: rotate(180deg);
    }

    .ai-luxury-footer-links-{{ ai_gen_id }} {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }

    .ai-luxury-footer-links-{{ ai_gen_id }}.active {
      max-height: 500px;
      padding-bottom: 20px;
    }

    .ai-luxury-footer-social-{{ ai_gen_id }} {
      margin-bottom: 30px;
    }

    .ai-luxury-footer-policies-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 12px;
    }
  }
{% endstyle %}

<luxury-footer-{{ ai_gen_id }} class="ai-luxury-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-luxury-footer-container-{{ ai_gen_id }}">
    <div class="ai-luxury-footer-brand-{{ ai_gen_id }}">
      {% if block.settings.logo != blank %}
        <img
          src="{{ block.settings.logo | image_url: width: 600 }}"
          alt="{{ shop.name }}"
          class="ai-luxury-footer-logo-{{ ai_gen_id }}"
          width="{{ block.settings.logo_width }}"
          height="auto"
          loading="lazy"
        >
      {% else %}
        <h2 class="ai-luxury-footer-brand-text-{{ ai_gen_id }}">{{ shop.name }}</h2>
      {% endif %}
    </div>

    <div class="ai-luxury-footer-nav-{{ ai_gen_id }}">
      {% if block.settings.menu_1 != blank %}
        <div class="ai-luxury-footer-column-{{ ai_gen_id }}">
          <button
            class="ai-luxury-footer-accordion-trigger-{{ ai_gen_id }}"
            aria-expanded="false"
            data-accordion-trigger
          >
            <h3 class="ai-luxury-footer-column-heading-{{ ai_gen_id }}">{{ block.settings.menu_1_heading }}</h3>
            <svg class="ai-luxury-footer-accordion-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="ai-luxury-footer-links-wrapper-{{ ai_gen_id }}">
            <h3 class="ai-luxury-footer-column-heading-{{ ai_gen_id }} ai-luxury-footer-desktop-heading-{{ ai_gen_id }}">{{ block.settings.menu_1_heading }}</h3>
            <ul class="ai-luxury-footer-links-{{ ai_gen_id }}" data-accordion-content>
              {% for link in linklists[block.settings.menu_1].links %}
                <li class="ai-luxury-footer-link-item-{{ ai_gen_id }}">
                  <a href="{{ link.url }}" class="ai-luxury-footer-link-{{ ai_gen_id }}">{{ link.title }}</a>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      {% endif %}

      {% if block.settings.menu_2 != blank %}
        <div class="ai-luxury-footer-column-{{ ai_gen_id }}">
          <button
            class="ai-luxury-footer-accordion-trigger-{{ ai_gen_id }}"
            aria-expanded="false"
            data-accordion-trigger
          >
            <h3 class="ai-luxury-footer-column-heading-{{ ai_gen_id }}">{{ block.settings.menu_2_heading }}</h3>
            <svg class="ai-luxury-footer-accordion-icon-{{ ai_gen_id }}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>
          <div class="ai-luxury-footer-links-wrapper-{{ ai_gen_id }}">
            <h3 class="ai-luxury-footer-column-heading-{{ ai_gen_id }} ai-luxury-footer-desktop-heading-{{ ai_gen_id }}">{{ block.settings.menu_2_heading }}</h3>
            <ul class="ai-luxury-footer-links-{{ ai_gen_id }}" data-accordion-content>
              {% for link in linklists[block.settings.menu_2].links %}
