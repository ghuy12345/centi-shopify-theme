    <div class="ai-luxury-footer-bottom-{{ ai_gen_id }}">
      <div class="ai-luxury-footer-copyright-{{ ai_gen_id }}">
        {% if block.settings.copyright_text != blank %}
          {{ block.settings.copyright_text | replace: '[year]', 'now' | date: '%Y' | replace: '[shop_name]', shop.name }}
        {% else %}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}
        {% endif %}
      </div>

      {% if block.settings.show_policy_links %}
        <ul class="ai-luxury-footer-policies-{{ ai_gen_id }}">
          {% if shop.privacy_policy %}
            <li>
              <a href="{{ shop.privacy_policy.url }}" class="ai-luxury-footer-policy-link-{{ ai_gen_id }}">
                {{ shop.privacy_policy.title }}
              </a>
            </li>
          {% endif %}
          {% if shop.refund_policy %}
            <li>
              <a href="{{ shop.refund_policy.url }}" class="ai-luxury-footer-policy-link-{{ ai_gen_id }}">
                {{ shop.refund_policy.title }}
              </a>
            </li>
          {% endif %}
          {% if shop.terms_of_service %}
            <li>
              <a href="{{ shop.terms_of_service.url }}" class="ai-luxury-footer-policy-link-{{ ai_gen_id }}">
                {{ shop.terms_of_service.title }}
              </a>
            </li>
          {% endif %}
          {% if shop.shipping_policy %}
            <li>
              <a href="{{ shop.shipping_policy.url }}" class="ai-luxury-footer-policy-link-{{ ai_gen_id }}">
                {{ shop.shipping_policy.title }}
              </a>
            </li>
          {% endif %}
        </ul>
      {% endif %}
    </div>
  </div>
</luxury-footer-{{ ai_gen_id }}>

<style>
  @media screen and (min-width: 750px) {
    .ai-luxury-footer-accordion-trigger-{{ ai_gen_id }} {
      display: none;
    }

    .ai-luxury-footer-desktop-heading-{{ ai_gen_id }} {
      display: block;
    }

    .ai-luxury-footer-links-{{ ai_gen_id }} {
      max-height: none;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-luxury-footer-desktop-heading-{{ ai_gen_id }} {
      display: none;
    }
  }
</style>

<script>
  (function() {
    class LuxuryFooter{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.setupAccordions();
      }

      setupAccordions() {
        const triggers = this.querySelectorAll('[data-accordion-trigger]');

        triggers.forEach((trigger) => {
          trigger.addEventListener('click', () => {
            const content = trigger.nextElementSibling.querySelector('[data-accordion-content]');
            const icon = trigger.querySelector('.ai-luxury-footer-accordion-icon-{{ ai_gen_id }}');
            const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

            trigger.setAttribute('aria-expanded', !isExpanded);
            content.classList.toggle('active');
            icon.classList.toggle('active');
          });
        });
      }
    }

    customElements.define('luxury-footer-{{ ai_gen_id }}', LuxuryFooter{{ ai_gen_id }});
  })();
</script>

