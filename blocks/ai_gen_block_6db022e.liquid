{% doc %}
  @prompt
    Create a minimal, editorial NEWSLETTER SIGNUP section for a luxury high-end women's
    fashion brand, inspired by arakii.com — lots of whitespace, clean, understated.
    
    FUNCTION (important)
    - Use Shopify's built-in email signup form (customer/newsletter form) so submissions
      are captured as real subscribers in Shopify. Do not make it a fake/non-working form.
    - Include a GDPR-style consent checkbox: "Yes, I consent to the privacy policy" with
      "privacy policy" as a link the merchant can set. Show a thank-you/success message
      after submit.
    
    LAYOUT (match the reference)
    - Large heading, left-aligned, in the theme's heading font, uppercase option
      (e.g. "BE A PART OF SENTE").
    - A short subtext paragraph below the heading.
    - An email input styled as a clean single underline (no box/border except a thin
      bottom line), with the placeholder "Your email" on the left and a text-only
      "SIGN UP" button on the right of the SAME line (no button box — just text).
    - The consent checkbox row sits below the email line.
    
    STYLE
    - Neutral, luxury, minimal. Use the theme's existing fonts and colors. Generous
      spacing/padding. Plenty of whitespace.
    
    RESPONSIVE / MOBILE-FIRST (90% of shoppers are on mobile)
    - On mobile it stacks cleanly and stays easy to tap; the email line and SIGN UP
      remain comfortable to use.
    
    EDITOR SETTINGS I WANT
    - Heading text, heading size, uppercase on/off, alignment (left/center).
    - Subtext text.
    - Email placeholder text and button label.
    - Consent checkbox label + privacy policy link.
    - Background color, text color, section top & bottom padding, content max-width.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-newsletter-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-newsletter-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .ai-newsletter-heading-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.heading_size }}px;
    font-weight: var(--font-heading-weight);
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-align: {{ block.settings.alignment }};
    {% if block.settings.heading_uppercase %}
      text-transform: uppercase;
    {% endif %}
  }

  .ai-newsletter-subtext-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    color: {{ block.settings.text_color }};
    margin: 0 0 40px 0;
    text-align: {{ block.settings.alignment }};
    opacity: 0.8;
  }

  .ai-newsletter-form-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.alignment }};
  }

  .ai-newsletter-email-row-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 20px;
    border-bottom: 1px solid {{ block.settings.text_color }};
    padding-bottom: 8px;
    margin-bottom: 16px;
    {% if block.settings.alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.alignment == 'center' %}
      justify-content: center;
    {% else %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-newsletter-email-input-{{ ai_gen_id }} {
    flex: 1;
    max-width: 400px;
    border: none;
    background: transparent;
    font-size: 14px;
    color: {{ block.settings.text_color }};
    padding: 0;
    outline: none;
  }

  .ai-newsletter-email-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.text_color }};
    opacity: 0.5;
  }

  .ai-newsletter-submit-{{ ai_gen_id }} {
    background: none;
    border: none;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    padding: 0;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .ai-newsletter-submit-{{ ai_gen_id }}:hover {
    opacity: 0.6;
  }

  .ai-newsletter-consent-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 20px;
    {% if block.settings.alignment == 'left' %}
      justify-content: flex-start;
    {% elsif block.settings.alignment == 'center' %}
      justify-content: center;
    {% else %}
      justify-content: flex-end;
    {% endif %}
  }

  .ai-newsletter-checkbox-{{ ai_gen_id }} {
    margin-top: 2px;
    cursor: pointer;
    flex-shrink: 0;
  }

  .ai-newsletter-consent-label-{{ ai_gen_id }} {
    font-size: 12px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    cursor: pointer;
  }

  .ai-newsletter-consent-label-{{ ai_gen_id }} a {
    color: {{ block.settings.text_color }};
    text-decoration: underline;
  }

  .ai-newsletter-consent-label-{{ ai_gen_id }} a:hover {
    opacity: 0.6;
  }

  .ai-newsletter-message-{{ ai_gen_id }} {
    font-size: 14px;
    line-height: 1.6;
    margin-top: 20px;
    text-align: {{ block.settings.alignment }};
  }

  .ai-newsletter-success-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  .ai-newsletter-error-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-newsletter-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-newsletter-email-row-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }

    .ai-newsletter-email-input-{{ ai_gen_id }} {
      max-width: 100%;
    }

    .ai-newsletter-submit-{{ ai_gen_id }} {
      align-self: flex-start;
    }

    .ai-newsletter-consent-{{ ai_gen_id }} {
      justify-content: flex-start;
    }
  }
{% endstyle %}

<newsletter-signup-{{ ai_gen_id }}
  class="ai-newsletter-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-newsletter-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-newsletter-heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <div class="ai-newsletter-subtext-{{ ai_gen_id }}">
        {{ block.settings.subtext }}
      </div>
    {% endif %}

    <div class="ai-newsletter-form-wrapper-{{ ai_gen_id }}">
      {% form 'customer', class: 'ai-newsletter-form' %}
        {% if form.posted_successfully? %}
          <div class="ai-newsletter-message-{{ ai_gen_id }} ai-newsletter-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {% else %}
          <input type="hidden" name="contact[tags]" value="newsletter">

          <div class="ai-newsletter-email-row-{{ ai_gen_id }}">
            <input
              type="email"
              name="contact[email]"
              class="ai-newsletter-email-input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.email_placeholder }}"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              required
              aria-required="true"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-newsletter-error-{{ ai_gen_id }}"
              {% endif %}
            >
            <button
              type="submit"
              class="ai-newsletter-submit-{{ ai_gen_id }}"
            >
              {{ block.settings.button_label }}
            </button>
          </div>

          <div class="ai-newsletter-consent-{{ ai_gen_id }}">
            <input
              type="checkbox"
              id="ai-newsletter-consent-{{ ai_gen_id }}"
              name="contact[accepts_marketing]"
              class="ai-newsletter-checkbox-{{ ai_gen_id }}"
              required
              aria-required="true"
            >
            <label
              for="ai-newsletter-consent-{{ ai_gen_id }}"
              class="ai-newsletter-consent-label-{{ ai_gen_id }}"
            >
              {{ block.settings.consent_text_before }}
              {% if block.settings.privacy_policy_link != blank %}
                <a href="{{ block.settings.privacy_policy_link }}">{{ block.settings.privacy_policy_text }}</a>
              {% else %}
                {{ block.settings.privacy_policy_text }}
              {% endif %}
            </label>
          </div>

          {% if form.errors %}
            <div
              id="ai-newsletter-error-{{ ai_gen_id }}"
              class="ai-newsletter-message-{{ ai_gen_id }} ai-newsletter-error-{{ ai_gen_id }}"
            >
              {{ form.errors.messages.email }}
            </div>
          {% endif %}
        {% endif %}
      {% endform %}
    </div>
  </div>
</newsletter-signup-{{ ai_gen_id }}>

<script>
  (function() {
    class NewsletterSignup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (!form) return;

        form.addEventListener('submit', (e) => {
          const checkbox = form.querySelector('input[type="checkbox"]');
          if (checkbox && !checkbox.checked) {
            e.preventDefault();
            alert('Please accept the privacy policy to continue.');
          }
        });
      }
    }

    customElements.define('newsletter-signup-{{ ai_gen_id }}', NewsletterSignup{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Newsletter signup",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "BE A PART OF SENTE"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "checkbox",
      "id": "heading_uppercase",
      "label": "Uppercase heading",
      "default": true
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Join our community and be the first to know about new collections, exclusive offers, and style inspiration."
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "SIGN UP"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for subscribing. Welcome to our community."
    },
    {
      "type": "header",
      "content": "Consent"
    },
    {
      "type": "text",
      "id": "consent_text_before",
      "label": "Consent text before link",
      "default": "Yes, I consent to the "
    },
    {
      "type": "text",
      "id": "privacy_policy_text",
      "label": "Privacy policy text",
      "default": "privacy policy"
    },
    {
      "type": "url",
      "id": "privacy_policy_link",
      "label": "Privacy policy link"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 400,
      "max": 1200,
      "step": 50,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Newsletter signup"
    }
  ]
}
{% endschema %}
