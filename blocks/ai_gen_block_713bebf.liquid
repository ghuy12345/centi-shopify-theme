{% doc %}
  @prompt
    can we add a rick text section header, with smaller text underneath with a cta button. let us change colours etc and make it fit well on deskktop and mobile, can we use the same fonts thats been used across the site please
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-header-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-header-content-{{ ai_gen_id }} {
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .ai-header-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    color: {{ block.settings.title_color }};
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    font-size: {{ block.settings.title_size_desktop }}px;
    line-height: 1.2;
  }

  .ai-header-subtitle-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.subtitle_spacing }}px 0;
    color: {{ block.settings.subtitle_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    font-size: {{ block.settings.subtitle_size_desktop }}px;
    line-height: 1.5;
  }

  .ai-header-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-style: {{ block.settings.button_font.style }};
    font-size: {{ block.settings.button_text_size }}px;
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-header-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
    border-color: {{ block.settings.button_border_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-header-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
    }

    .ai-header-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_mobile }}px;
    }

    .ai-header-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size_mobile }}px;
    }

    .ai-header-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size_mobile }}px;
    }
  }
{% endstyle %}

<rich-text-header-{{ ai_gen_id }} class="ai-header-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-header-content-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <div class="ai-header-title-{{ ai_gen_id }}">
        {{ block.settings.title }}
      </div>
    {% endif %}

    {% if block.settings.subtitle != blank %}
      <div class="ai-header-subtitle-{{ ai_gen_id }}">
        {{ block.settings.subtitle }}
      </div>
    {% endif %}

    {% if block.settings.button_text != blank %}
      <a href="{{ block.settings.button_link }}" class="ai-header-button-{{ ai_gen_id }}">
        {{ block.settings.button_text }}
      </a>
    {% endif %}
  </div>
</rich-text-header-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Rich text header",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Heading",
      "default": "<p>Welcome to our store</p>"
