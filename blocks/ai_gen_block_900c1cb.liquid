{% doc %}
  @prompt
    Create an editorial "mood board" image grid section for a luxury high-end women's
    fashion brand, inspired by Self-Portrait's homepage.

    LAYOUT: an asymmetric mosaic / masonry grid of images in mixed sizes — one large
    feature tile alongside smaller tiles — that together create a curated, editorial
    mood. Some tiles span 2 columns / 2 rows. Spacious, minimal, generous whitespace.

    TILES: each tile is optionally clickable (product or collection), with an optional
    caption and a subtle hover zoom/fade. One tile can be a VIDEO instead of an image:
    the video autoplays muted, loops, and has no play/pause controls.

    AESTHETIC: clean, minimal, luxury, neutral. Portrait (3:4) default, sharp corners
    default (adjustable). Match the theme's fonts and colours.

    HEADING: optional heading with size, alignment, uppercase controls.

    RESPONSIVE / MOBILE-FIRST. Reflows into a clean stack on mobile.

    EDITOR SETTINGS: up to 8 tiles; per tile image OR video, link, caption, feature
    toggle; grid gap, corner radius, section top & bottom padding, heading, background.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-mood-grid-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-mood-grid-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-mood-grid-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.grid_gap }}px;
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.heading_alignment }};
    color: {{ block.settings.heading_color }};
    letter-spacing: 0.05em;
    {% if block.settings.heading_uppercase %}
      text-transform: uppercase;
    {% endif %}
  }

  .ai-mood-grid-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.grid_gap }}px;
  }

  .ai-mood-tile-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.corner_radius }}px;
    background-color: #f5f5f5;
  }

  .ai-mood-tile-{{ ai_gen_id }}.feature {
    grid-column: span 2;
    grid-row: span 2;
  }

  .ai-mood-tile-link-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
  }

  .ai-mood-tile-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 133.33%;
    overflow: hidden;
  }

  .ai-mood-tile-{{ ai_gen_id }}.feature .ai-mood-tile-image-wrapper-{{ ai_gen_id }} {
    padding-bottom: 66.66%;
  }

  .ai-mood-tile-image-{{ ai_gen_id }},
  .ai-mood-tile-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.6s ease;
  }

  .ai-mood-tile-link-{{ ai_gen_id }}:hover .ai-mood-tile-image-{{ ai_gen_id }},
  .ai-mood-tile-link-{{ ai_gen_id }}:hover .ai-mood-tile-video-{{ ai_gen_id }} {
    transform: scale(1.05);
    opacity: 0.9;
  }

  .ai-mood-tile-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f5f5f5;
  }

  .ai-mood-tile-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-mood-tile-caption-{{ ai_gen_id }} {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 20px;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
    color: #ffffff;
    font-size: 14px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 2;
  }

  .ai-mood-tile-link-{{ ai_gen_id }}:hover .ai-mood-tile-caption-{{ ai_gen_id }} {
    opacity: 1;
  }

  @media screen and (max-width: 989px) {
    .ai-mood-grid-wrapper-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }

    .ai-mood-tile-{{ ai_gen_id }}.feature {
      grid-column: span 2;
      grid-row: span 1;
    }

    .ai-mood-tile-{{ ai_gen_id }}.feature .ai-mood-tile-image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 100%;
    }

    .ai-mood-grid-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-mood-grid-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap | times: 0.75 }}px;
    }

    .ai-mood-tile-{{ ai_gen_id }}.feature {
      grid-column: span 1;
      grid-row: span 1;
    }

    .ai-mood-tile-{{ ai_gen_id }}.feature .ai-mood-tile-image-wrapper-{{ ai_gen_id }} {
      padding-bottom: 133.33%;
    }

    .ai-mood-grid-container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-mood-grid-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
      margin-bottom: {{ block.settings.grid_gap | times: 0.75 }}px;
    }
  }
{% endstyle %}

<mood-board-grid-{{ ai_gen_id }} class="ai-mood-grid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-mood-grid-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-mood-grid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-mood-grid-wrapper-{{ ai_gen_id }}">
      {% for i in (1..8) %}
        {% liquid
          assign tile_enabled_key = 'tile_' | append: i | append: '_enabled'
          assign tile_image_key = 'tile_' | append: i | append: '_image'
          assign tile_video_key = 'tile_' | append: i | append: '_video'
          assign tile_link_key = 'tile_' | append: i | append: '_link'
          assign tile_caption_key = 'tile_' | append: i | append: '_caption'
          assign tile_feature_key = 'tile_' | append: i | append: '_feature'

          assign tile_enabled = block.settings[tile_enabled_key]
          assign tile_image = block.settings[tile_image_key]
          assign tile_video = block.settings[tile_video_key]
          assign tile_link = block.settings[tile_link_key]
          assign tile_caption = block.settings[tile_caption_key]
          assign tile_feature = block.settings[tile_feature_key]
        %}

        {% if tile_enabled %}
          <div class="ai-mood-tile-{{ ai_gen_id }} {% if tile_feature %}feature{% endif %}">
            {% if tile_link != blank %}
              <a href="{{ tile_link }}" class="ai-mood-tile-link-{{ ai_gen_id }}">
            {% else %}
              <div class="ai-mood-tile-link-{{ ai_gen_id }}">
            {% endif %}
              <div class="ai-mood-tile-image-wrapper-{{ ai_gen_id }}">
                {% if tile_video != blank %}
                  {% assign video_class = 'ai-mood-tile-video-' | append: ai_gen_id %}
                  {{
                    tile_video
                    | video_tag:
                      autoplay: true,
                      loop: true,
                      muted: true,
                      controls: false,
                      playsinline: true,
                      class: video_class
                  }}
                {% elsif tile_image %}
                  <img
                    src="{{ tile_image | image_url: width: 1200 }}"
                    alt="{{ tile_image.alt | escape }}"
                    loading="lazy"
                    width="{{ tile_image.width }}"
                    height="{{ tile_image.height }}"
                    class="ai-mood-tile-image-{{ ai_gen_id }}"
                  >
                {% else %}
                  <div class="ai-mood-tile-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              {% if tile_caption != blank %}
                <div class="ai-mood-tile-caption-{{ ai_gen_id }}">
                  {{ tile_caption }}
                </div>
              {% endif %}

            {% if tile_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</mood-board-grid-{{ ai_gen_id }}>

