{% doc %}
  @prompt
    can you create a waitlist sign up link with an email box in the same fonts as the store. text saying safi black launching 4pm Uk time. , fonts need to be luxury like the stores fonts we used, add in an image and we need better fonts like the logo at the top, needs to be like the logo centi
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-waitlist-signup-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-waitlist-signup__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
    margin: 0 auto;
    max-width: {{ block.settings.max_content_width }}px;
  }

  .ai-waitlist-signup__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-waitlist-signup__image-{{ ai_gen_id }} {
    max-width: {{ block.settings.image_width }}px;
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-waitlist-signup__image-placeholder-{{ ai_gen_id }} {
    max-width: {{ block.settings.image_width }}px;
    width: 100%;
    margin: 0 auto;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-waitlist-signup__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-waitlist-signup__heading-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    text-align: {{ block.settings.text_alignment }};
    line-height: 1.1;
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-style: {{ block.settings.heading_font.style }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}em;
    text-transform: {{ block.settings.heading_text_transform }};
  }

  .ai-waitlist-signup__subtext-{{ ai_gen_id }} {
    color: {{ block.settings.subtext_color }};
    font-size: {{ block.settings.subtext_size }}px;
    text-align: {{ block.settings.text_alignment }};
    margin: 0;
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    font-style: {{ block.settings.body_font.style }};
    letter-spacing: {{ block.settings.body_letter_spacing }}em;
  }

  .ai-waitlist-signup__field-wrapper-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-waitlist-signup__field-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.field_gap }}px;
    flex-direction: {{ block.settings.field_layout }};
  }

  .ai-waitlist-signup__input-{{ ai_gen_id }} {
    flex-grow: 1;
    padding: {{ block.settings.input_padding }}px {{ block.settings.input_padding_horizontal }}px;
    border: {{ block.settings.input_border_width }}px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_font_size }}px;
    background-color: {{ block.settings.input_background_color }};
    color: {{ block.settings.input_text_color }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
    font-weight: {{ block.settings.body_font.weight }};
    letter-spacing: {{ block.settings.input_letter_spacing }}em;
  }

  .ai-waitlist-signup__input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
    opacity: 0.7;
  }

  .ai-waitlist-signup__input-{{ ai_gen_id }}:focus {
    outline: 2px solid {{ block.settings.button_color }};
    outline-offset: 2px;
  }

  .ai-waitlist-signup__button-{{ ai_gen_id }} {
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    cursor: pointer;
    font-size: {{ block.settings.button_font_size }}px;
    font-family: {{ block.settings.button_font.family }}, {{ block.settings.button_font.fallback_families }};
    font-weight: {{ block.settings.button_font.weight }};
    font-style: {{ block.settings.button_font.style }};
    letter-spacing: {{ block.settings.button_letter_spacing }}em;
    text-transform: {{ block.settings.button_text_transform }};
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  .ai-waitlist-signup__button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-waitlist-signup__success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: 8px;
    font-size: {{ block.settings.message_font_size }}px;
    text-align: {{ block.settings.text_alignment }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
  }

  .ai-waitlist-signup__error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 8px;
    font-size: {{ block.settings.message_font_size }}px;
    text-align: {{ block.settings.text_alignment }};
    font-family: {{ block.settings.body_font.family }}, {{ block.settings.body_font.fallback_families }};
  }

  @media screen and (max-width: 749px) {
    .ai-waitlist-signup-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-waitlist-signup__field-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-waitlist-signup__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.85);
    }

    .ai-waitlist-signup__subtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.subtext_size }}px * 0.9);
    }

    .ai-waitlist-signup__image-{{ ai_gen_id }},
    .ai-waitlist-signup__image-placeholder-{{ ai_gen_id }} {
      max-width: {{ block.settings.image_width_mobile }}px;
    }
  }
{% endstyle %}

<waitlist-signup-{{ ai_gen_id }}
  class="ai-waitlist-signup-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {%- form 'contact' -%}
    <input
      type="hidden"
      name="contact[waitlist_product]"
      value="{{ block.settings.product_name }}"
    >
    <div class="ai-waitlist-signup__content-{{ ai_gen_id }}">
      {%- if block.settings.show_image -%}
        <div class="ai-waitlist-signup__image-wrapper-{{ ai_gen_id }}">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              class="ai-waitlist-signup__image-{{ ai_gen_id }}"
            >
          {%- else -%}
            <div class="ai-waitlist-signup__image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if block.settings.heading != blank -%}
        <h2 class="ai-waitlist-signup__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {%- endif -%}

      {%- if block.settings.subtext != blank -%}
        <p class="ai-waitlist-signup__subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
      {%- endif -%}

      <div class="ai-waitlist-signup__field-wrapper-{{ ai_gen_id }}">
        <div class="ai-waitlist-signup__field-{{ ai_gen_id }}">
          <input
            type="email"
            name="contact[email]"
            class="ai-waitlist-signup__input-{{ ai_gen_id }}"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="ai-waitlist-signup-error-{{ ai_gen_id }}"
            {% endif %}
            {% if form.posted_successfully? %}
              aria-describedby="ai-waitlist-signup-success-{{ ai_gen_id }}"
            {% endif %}
            placeholder="{{ block.settings.email_placeholder }}"
            required
          >
          <button
            type="submit"
            class="ai-waitlist-signup__button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_label }}
          </button>
        </div>
        {%- if form.errors -%}
          <div
            id="ai-waitlist-signup-error-{{ ai_gen_id }}"
            class="ai-waitlist-signup__error-{{ ai_gen_id }}"
          >
            <span>{{ form.errors.messages.email }}</span>
          </div>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <div
            id="ai-waitlist-signup-success-{{ ai_gen_id }}"
            class="ai-waitlist-signup__success-{{ ai_gen_id }}"
          >
            <span>{{ block.settings.success_message }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  {%- endform -%}
</waitlist-signup-{{ ai_gen_id }}>

<script>
  (function() {
    class WaitlistSignup{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const form = this.querySelector('form');
        if (form && form.classList.contains('contact-form')) {
          form.addEventListener('submit', () => {
            const button = this.querySelector('.ai-waitlist-signup__button-{{ ai_gen_id }}');
            if (button) {
              button.disabled = true;
              button.textContent = 'Submitting...';
            }
          });
        }
      }
    }

    customElements.define('waitlist-signup-{{ ai_gen_id }}', WaitlistSignup{{ ai_gen_id }});
  })();
</script>

