      }
      .fss-left {
        flex: 1 1 auto;
        max-width: 100%;
        text-align: center;
      }
      .fss-controls {
        justify-content: center;
      }

      .fss-left {
    display: flex;
    flex-direction: column;
}
.custom-fss-all-top {
    width: 100%;
    max-width: 100%;
}
    }
</style>

<script>
  (function () {
    const section = document.querySelector('[data-section-type="featured-stories-slider"]');
    if (!section) return;

    const wrapper = section.querySelector('#fss-slides-wrapper');
    const slides = wrapper ? wrapper.querySelectorAll('.fss-slide') : [];
    const total = slides.length;
    if (total === 0) return;

    const controls = section.querySelector('#fss-controls');
    const prevBtn = section.querySelector('.fss-prev');
    const nextBtn = section.querySelector('.fss-next');
    const progressFill = section.querySelector('.fss-progress-fill');

    const sliderEnabled = section.dataset.sliderEnabled === 'true';
    const slidesDesktop = parseFloat(section.dataset.slidesDesktop) || 3.5;
    const slidesMobile = parseFloat(section.dataset.slidesMobile) || 1.5;

    function getVisibleSlides() {
      if (window.innerWidth >= 1024) return slidesDesktop;
      if (window.innerWidth >= 768) return Math.min(slidesDesktop, 2.5);
      return slidesMobile;
    }

    let currentIndex = 0;
    let startX = 0;
    let isDragging = false;

    function isSliderActive() {
      if (!sliderEnabled) return false;
      const visible = getVisibleSlides();
      return total > Math.ceil(visible);
    }

    function getMaxIndex() {
      const visible = getVisibleSlides();
      return Math.max(0, total - Math.ceil(visible));
    }

    function updateSliderState() {
      const active = isSliderActive();

      if (active) {
        wrapper.classList.remove('is-static');
        controls.classList.remove('is-hidden');
        wrapper.style.flexWrap = 'nowrap';
        updateSliderPosition();
      } else {
        wrapper.classList.add('is-static');
        controls.classList.add('is-hidden');
        wrapper.style.transform = 'translateX(0px)';
        wrapper.style.flexWrap = 'wrap';
        if (progressFill) progressFill.style.width = '0%';
        prevBtn.disabled = true;
        nextBtn.disabled = true;
      }
    }

    function updateSliderPosition() {
      if (!isSliderActive()) return;

      const maxIndex = getMaxIndex();
      if (currentIndex > maxIndex) currentIndex = maxIndex;
      if (currentIndex < 0) currentIndex = 0;

      const slide = slides[0];
      if (!slide) return;
      const slideWidth = slide.offsetWidth;
      const gap = 20;
      const offset = currentIndex * (slideWidth + gap);

      wrapper.style.transform = `translateX(-${offset}px)`;

      const progress = maxIndex === 0 ? 0 : (currentIndex / maxIndex) * 100;
      if (progressFill) progressFill.style.width = progress + '%';

      prevBtn.disabled = currentIndex === 0;
      nextBtn.disabled = currentIndex === maxIndex;

      const progressBar = section.querySelector('.fss-progress-bar');
      if (progressBar) {
        progressBar.setAttribute('aria-valuenow', currentIndex);
        progressBar.setAttribute('aria-valuemax', maxIndex);
      }
    }

    function goTo(index) {
      if (!isSliderActive()) return;
      const maxIndex = getMaxIndex();
      currentIndex = Math.min(Math.max(index, 0), maxIndex);
      updateSliderPosition();
    }

    function goPrev() {
      goTo(currentIndex - 1);
    }
    function goNext() {
      goTo(currentIndex + 1);
    }

    if (prevBtn) prevBtn.addEventListener('click', goPrev);
    if (nextBtn) nextBtn.addEventListener('click', goNext);

    const container = section.querySelector('.fss-slider-container');
    if (container) {
      container.addEventListener('touchstart', function(e) {
        if (!isSliderActive()) return;
        startX = e.touches[0].clientX;
        isDragging = true;
      }, { passive: true });

      container.addEventListener('touchmove', function(e) {
      }, { passive: true });

      container.addEventListener('touchend', function(e) {
        if (!isDragging || !isSliderActive()) return;
        isDragging = false;
        const endX = e.changedTouches[0].clientX;
        const diff = startX - endX;
        if (Math.abs(diff) > 40) { 
          if (diff > 0) {
            goNext();
          } else {
            goPrev();
          }
        }
      }, { passive: true });
    }

    let resizeTimeout;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const maxIndex = getMaxIndex();
        if (currentIndex > maxIndex) currentIndex = maxIndex;
        updateSliderState();
        if (isSliderActive()) {
          updateSliderPosition();
        }
      }, 200);
    });

    const style = document.createElement('style');
    const desktopBasis = 100 / slidesDesktop;
    const mobileBasis = 100 / slidesMobile;
    style.textContent = `
      .fss-slide {
        flex: 0 0 calc(${desktopBasis}% - 15px);
      }
      @media screen and (max-width: 1024px) and (min-width: 769px) {
        .fss-slide {
          flex: 0 0 calc(${100 / Math.min(slidesDesktop, 2.5)}% - 15px);
        }
      }
      @media screen and (max-width: 768px) {
        .fss-slide {
          flex: 0 0 calc(${mobileBasis}% - 15px);
        }
      }
      /* Static grid override – full width with wrap */
      .fss-slides-wrapper.is-static .fss-slide {
        flex: 0 0 calc(${100 / Math.min(slidesDesktop, 4)}% - 15px);
      }
      @media screen and (max-width: 768px) {
        .fss-slides-wrapper.is-static .fss-slide {
          flex: 0 0 calc(50% - 10px);
        }
      }
      @media screen and (max-width: 480px) {
        .fss-slides-wrapper.is-static .fss-slide {
          flex: 0 0 calc(100% - 0px);
        }
      }
    `;
    document.head.appendChild(style);

    updateSliderState();
    if (isSliderActive()) {
      updateSliderPosition();
    }
  })();
</script>