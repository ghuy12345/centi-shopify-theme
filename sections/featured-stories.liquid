    },
    {
      "type": "checkbox",
      "id": "heading_text_shadow",
      "label": "Enable Text Shadow",
      "default": false
    },
    {
      "type": "header",
      "content": "⭐ Subheading Settings"
    },
    {
      "type": "range",
      "id": "subheading_font_size_desktop",
      "label": "Subheading Font Size (Desktop)",
      "min": 10,
      "max": 30,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "subheading_font_size_mobile",
      "label": "Subheading Font Size (Mobile)",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#999999"
    },
    {
      "type": "checkbox",
      "id": "subheading_text_shadow",
      "label": "Enable Text Shadow",
      "default": false
    },
    {
      "type": "header",
      "content": "⭐ Text Settings"
    },
    {
      "type": "range",
      "id": "text_font_size_desktop",
      "label": "Text Font Size (Desktop)",
      "min": 10,
      "max": 30,
      "step": 1,
      "default": 14
    },
    {
      "type": "range",
      "id": "text_font_size_mobile",
      "label": "Text Font Size (Mobile)",
      "min": 8,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    },
    {
      "type": "video",
      "name": "Video",
      "settings": [
        {
          "type": "url",
          "id": "video_url",
          "label": "Video file URL",
          "info": "Upload your video to Shopify Files, copy the URL, and paste it here. Supports .mp4, .mov, etc."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Stories Slider",
      "category": "Custom",
      "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "video" }]
    }
  ]
}
{% endschema %}

<style>
    .fss-wrapper {
      max-width: 1200px;
      margin: 0 auto;
      padding: 40px 15px;
      font-family: var(--font-body-family, sans-serif);
    }

    .fss-grid {
      gap: 40px;
      align-items: flex-start;
      flex-wrap: wrap;
    }

  .fss-left {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      padding-bottom: 36px;
  }

  .custom-fss-all-top {
      width: 100%;
      max-width: 30%;
  }
    .fss-subheading {
      letter-spacing: 2px;
      text-transform: uppercase;
      margin: 0 0 5px;
      font-weight: 600;
    }
    .fss-heading {
      margin: 0 0 10px;
      font-weight: 700;
      line-height: 1.2;
      text-transform: uppercase;
    }
    .fss-text {
      line-height: 1.6;
      margin: 0;
    }

    .fss-right {
      flex: 1;
      min-width: 0;
    }

   .fss-controls {
    display: flex;
    justify-content: flex-end;
    gap: 15px;
    min-height: 40px;
    flex-direction: column;
    align-items: baseline;
}

    .fss-controls.is-hidden {
      display: none;
    }

    .fss-progress-bar {
      width: 200px;
      height: 2px;
      background: #e0e0e0;
      border-radius: 2px;
      flex-shrink: 0;
      position: relative;
    }
    .fss-progress-fill {
      display: block;
      height: 100%;
      width: 0%;
      background: #000;
      border-radius: 2px;
      transition: width 0.3s ease;
    }

    .fss-buttons {
      display: flex;
      gap: 10px;
    }
 button.fss-prev {
    padding: 0px;
    background: none;
    border: none;
    cursor: pointer;
}

button.fss-next {
 padding: 0px;
    background: none;
    border: none;
    cursor: pointer;
}

    .fss-slider-container {
      position: relative;
      overflow: hidden;
    }

    .fss-slides-wrapper {
      display: flex;
      gap: 2px;
      transition: transform 0.4s ease-in-out;
      will-change: transform;
    }
    .fss-slides-wrapper {
      flex-wrap: nowrap;
    }
    .fss-slides-wrapper.is-static {
      flex-wrap: wrap;
      transform: none !important;
    }

    .fss-slide {
      min-width: 0;
      box-sizing: border-box;
    }

    .fss-media-block {
      position: relative;
      background: #fafafa;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .fss-media-block img,
    .fss-media-block video {
      width: 100%;
