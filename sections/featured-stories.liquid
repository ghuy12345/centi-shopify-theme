<style>
  .fss-heading {
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    color: {{ section.settings.heading_color }};
    {% if section.settings.heading_text_shadow %}text-shadow: 0 2px 8px rgba(0,0,0,0.3);{% endif %}
  }
  .fss-subheading {
    font-size: {{ section.settings.subheading_font_size_desktop }}px;
    color: {{ section.settings.subheading_color }};
    {% if section.settings.subheading_text_shadow %}text-shadow: 0 2px 8px rgba(0,0,0,0.3);{% endif %}
  }
  .fss-text {
    font-size: {{ section.settings.text_font_size_desktop }}px;
    color: {{ section.settings.text_color }};
  }
  @media screen and (max-width: 768px) {
    .fss-heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
    .fss-subheading {
      font-size: {{ section.settings.subheading_font_size_mobile }}px;
    }
    .fss-text {
      font-size: {{ section.settings.text_font_size_mobile }}px;
    }
    div#fss-controls {
    display: none;
}
  }
</style>

<div
  class="fss-wrapper"
  data-section-id="{{ section.id }}"
  data-section-type="featured-stories-slider"
  data-slider-enabled="{{ section.settings.enable_slider }}"
  data-slides-desktop="{{ section.settings.slides_per_view_desktop }}"
  data-slides-mobile="{{ section.settings.slides_per_view_mobile }}"
>
  <div class="fss-grid">
    <div class="fss-left">
      <div class="custom-fss-all-top">
        {% if section.settings.subheading != blank %}
          <p class="fss-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="fss-heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="fss-text">{{ section.settings.text }}</div>
        {% endif %}
      </div>

      <div class="fss-controls" id="fss-controls">
        <div class="fss-buttons">
          <button class="fss-prev" aria-label="Previous slide" disabled>
            <svg xmlns="http://www.w3.org/2000/svg" width="25" height="8" viewBox="0 0 25 8" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M-0.000362717 4.33334L4.86719 8L2.51091 4.69995L24.8906 4.69995L24.8906 3.69995L2.45142 3.69995L4.8131 1.75523e-06L-0.000362717 4.33334Z" fill="black"></path>
            </svg>
          </button>
          <button class="fss-next" aria-label="Next slide">
            <svg xmlns="http://www.w3.org/2000/svg" width="25" height="8" viewBox="0 0 25 8" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M24.891 3.66667L20.0234 0L22.3797 3.30005H0V4.30005H22.4392L20.0775 8L24.891 3.66667Z" fill="black"></path>
            </svg>
          </button>
        </div>
        <div class="fss-progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="0">
          <span class="fss-progress-fill" style="width: 0%;"></span>
        </div>
        
      </div>
    </div>

    <div class="fss-right">
      <div class="fss-slider-container">
        <div class="fss-slides-wrapper" id="fss-slides-wrapper">
          {% for block in section.blocks %}
            <div class="fss-slide" data-index="{{ forloop.index0 }}">
              <div class="fss-media-block">
                {% if block.type == 'image' %}
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | img_url: '800x800' }}"
                      alt="{{ block.settings.image.alt | default: 'Story image' }}"
                      loading="lazy"
                    >
                  {% else %}
                    <div class="fss-placeholder">Add an image</div>
                  {% endif %}
                {% elsif block.type == 'video' %}
                  {% if block.settings.video_url != blank %}
                    <video
                      src="{{ block.settings.video_url }}"
                      autoplay
                      muted
                      loop
                      playsinline
                      preload="metadata"
                    ></video>
                  {% else %}
                    <div class="fss-placeholder">Add a video URL</div>
                  {% endif %}
                {% endif %}
              </div>
            </div>
          {% else %}
            <div class="fss-empty">Add blocks (image or video) to this section.</div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Featured Stories Slider",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "STYLEDBYYOU"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "#ARCINAORI"
