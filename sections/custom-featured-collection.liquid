{{ 'featured-collection-slider.css' | asset_url | stylesheet_tag }}

<style>
  .fcs-heading {
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    color: {{ section.settings.heading_color }};
    {% if section.settings.heading_text_shadow %}text-shadow: 0 2px 8px rgba(0,0,0,0.3);{% endif %}
  }
  .fcs-subheading {
    font-size: {{ section.settings.subheading_font_size_desktop }}px;
    color: {{ section.settings.subheading_color }};
    {% if section.settings.subheading_text_shadow %}text-shadow: 0 2px 8px rgba(0,0,0,0.3);{% endif %}
  }
  @media screen and (max-width: 768px) {
    .fcs-heading {
      font-size: {{ section.settings.heading_font_size_mobile }}px;
    }
    .fcs-subheading {
      font-size: {{ section.settings.subheading_font_size_mobile }}px;
    }
    div#fcs-controls {
    display: none;
}
  }
</style>

<div 
  class="fcs-wrapper" 
  data-section-id="{{ section.id }}" 
  data-section-type="featured-collection-slider"
  data-slider-enabled="{{ section.settings.enable_slider }}"
  data-columns="{{ section.settings.columns_desktop }}"
>
  <div class="fcs-header" style="text-align: {{ section.settings.heading_alignment }};">
    {% if section.settings.subheading != blank %}
      <p class="fcs-subheading">{{ section.settings.subheading }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="fcs-heading">{{ section.settings.heading }}</h2>
    {% endif %}
  </div>

  {%- assign collection = collections[section.settings.collection] -%}
  {%- assign products = collection.products | limit: section.settings.products_limit -%}

  <div class="fcs-slider-container">
    <div class="fcs-slides-wrapper" id="fcs-slides-wrapper">
      {% for product in products %}
        <div class="fcs-slide" data-index="{{ forloop.index0 }}">
          <div class="fcs-product-card">
            
            {% assign product_tags = product.tags | downcase %}
            {% if product_tags contains 'new' %}
              <span class="fcs-badge">NEW</span>
            {% elsif product.compare_at_price > product.price %}
              <span class="fcs-badge sale">SALE</span>
            {% endif %}

            {% if product.featured_image %}
              <a href="{{ product.url }}" class="fcs-image-link">
                <img 
                  src="{{ product.featured_image | img_url: '500x500' }}" 
                  alt="{{ product.title | escape }}" 
                  loading="lazy"
                >
              </a>
            {% endif %}

            <div class="fcs-product-info">
                <div class="custom-fcs-title-var">
              <h3 class="fcs-product-title" 
                  style="font-size: {{ section.settings.title_font_size }}px; 
                         color: {{ section.settings.title_color }};
                         {% if section.settings.title_text_shadow %}text-shadow: 0 1px 4px rgba(0,0,0,0.4);{% endif %}">
                {{ product.title | upcase }}
              </h3>
              
              <div class="fcs-product-variants"
                   style="font-size: {{ section.settings.variant_font_size }}px; 
                          color: {{ section.settings.variant_color }};
                          {% if section.settings.variant_text_shadow %}text-shadow: 0 1px 4px rgba(0,0,0,0.4);{% endif %}">
                {%- assign size_option = nil -%}
                {% for option in product.options_with_values %}
                  {% assign option_name = option.name | downcase %}
                  {% if option_name contains 'size' %}
                    {% assign size_option = option %}
                    {% break %}
                  {% endif %}
                {% endfor %}

                {% if size_option == nil %}
                  {% assign size_option = product.options_with_values[0] %}
                {% endif %}

                {% if size_option.values.size > 0 %}
                  {{ size_option.values | join: ' ' }}
                {% else %}
                  ONE SIZE
                {% endif %}
              </div>
            </div>

              <div class="fcs-product-price"
                   style="font-size: {{ section.settings.price_font_size }}px; 
                          color: {{ section.settings.price_color }};
                          {% if section.settings.price_text_shadow %}text-shadow: 0 1px 4px rgba(0,0,0,0.4);{% endif %}">
                {{ product.price | money_with_currency }}
              </div>
            </div>

          </div>
        </div>
      {% else %}
        <div class="fcs-empty">No products found in this collection.</div>
      {% endfor %}
    </div>

    <div class="fcs-controls" id="fcs-controls">
        <div class="fcs-buttons">
        <button class="fcs-prev" aria-label="Previous slide" disabled> <svg xmlns="http://www.w3.org/2000/svg" width="25" height="8" viewBox="0 0 25 8" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M-0.000362717 4.33334L4.86719 8L2.51091 4.69995L24.8906 4.69995L24.8906 3.69995L2.45142 3.69995L4.8131 1.75523e-06L-0.000362717 4.33334Z" fill="black"></path>
            </svg></button>
        <button class="fcs-next" aria-label="Next slide"> <svg xmlns="http://www.w3.org/2000/svg" width="25" height="8" viewBox="0 0 25 8" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M24.891 3.66667L20.0234 0L22.3797 3.30005H0V4.30005H22.4392L20.0775 8L24.891 3.66667Z" fill="black"></path>
            </svg></button>
      </div>
      <div class="fcs-progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="{{ products.size | minus: 1 }}">
        <span class="fcs-progress-fill" style="width: 0%;"></span>
      </div>
      
    </div>
  </div>
</div>

<style>
  .fcs-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 20px 15px;
    font-family: var(--font-body-family, sans-serif);
  }

  .fcs-header {
    margin-bottom: 30px;
  }
  
  .fcs-subheading {
    letter-spacing: 2px;
    text-transform: uppercase;
    margin: 0 0 5px;
  }
  .fcs-heading {
    margin: 0;
    font-weight: 600;
  }

  .fcs-slider-container {
    position: relative;
    overflow: hidden;
  }

  .fcs-slides-wrapper {
    display: flex;
    gap: 2px;
    transition: transform 0.4s ease-in-out;
    will-change: transform;
  }

  .fcs-slides-wrapper {
    flex-wrap: nowrap;
  }
  .fcs-slides-wrapper.is-static {
    flex-wrap: wrap;
    transform: none !important;
  }

  .fcs-slide {
    flex: 0 0 calc(25% - 15px); 
    min-width: 0;
    box-sizing: border-box;
  }

  @media screen and (max-width: 1024px) {
    .fcs-slide { flex: 0 0 calc(33.333% - 14px); }
  }
  @media screen and (max-width: 768px) {
    .fcs-slide { flex: 0 0 calc(66.666% - 10px); }
  }
  @media screen and (max-width: 480px) {
    .fcs-slide { flex: 0 0 calc(66.666% - 10px); }
  }

  .fcs-slides-wrapper.is-static .fcs-slide {
    flex: 0 0 calc(25% - 15px);
  }
  @media screen and (max-width: 1024px) {
    .fcs-slides-wrapper.is-static .fcs-slide { flex: 0 0 calc(33.333% - 14px); }
  }
  @media screen and (max-width: 768px) {
    .fcs-slides-wrapper.is-static .fcs-slide { flex: 0 0 calc(50% - 10px); }
  }
  @media screen and (max-width: 480px) {
    .fcs-slides-wrapper.is-static .fcs-slide { flex: 0 0 calc(100% - 0px); }
  }

  .fcs-product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid #eee;
    overflow: hidden;
    height: 100%;
    transition: box-shadow 0.2s;
  }


  .fcs-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #000;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 2px 12px;
    border-radius: 2px;
    text-transform: uppercase;
    z-index: 2;
  }
  .fcs-badge.sale {
    background: #c00;
  }

  .fcs-image-link {
    display: block;
    flex: 1 1 auto; 
    overflow: hidden;
    background: #fafafa;
  }
  .fcs-image-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

.fcs-product-info {
    padding: 8px 10px 12px;
    text-align: center;
    background: #ffffff0d;
    flex-shrink: 0;
    position: absolute;
    bottom: 0px;
    width: 100%;
}

  .fcs-product-title,
  .fcs-product-variants,
  .fcs-product-price {
    line-height: 1.5;
    margin: 0;
    padding: 2px 0;
    letter-spacing: 0.3px;
  }

  .fcs-product-title {
    font-weight: 700;
    text-transform: uppercase;
  }

  .fcs-product-variants {
    font-weight: 400;
  }

  .fcs-product-price {
    font-weight: 600;
  }

  .fcs-controls {
    display: flex;
    align-items: center;
    justify-content: flex-start; 
    gap: 15px;
    margin-top: 25px;
    min-height: 40px;
  }

  .fcs-controls.is-hidden {
    display: none;
  }

  .fcs-progress-bar {
    width: 200px; 
    height: 2px;
    background: #e0e0e0;
    border-radius: 2px;
    flex-shrink: 0;
    position: relative;
  }
  .fcs-progress-fill {
    display: block;
    height: 100%;
    width: 0%;
    background: #000;
    border-radius: 2px;
    transition: width 0.3s ease;
  }

  .fcs-buttons {
    display: flex;
    gap: 10px;
  }
   .fcs-buttons {
      display: flex;
      gap: 10px;
    }
 button.fcs-prev {
    padding: 0px;
    background: none;
    border: none;
    cursor: pointer;
}

button.fcs-next {
 padding: 0px;
    background: none;
    border: none;
    cursor: pointer;
}

  .fcs-empty {
    text-align: center;
    padding: 40px 0;
    width: 100%;
    color: #999;
  }
</style>

<script>
  (function() {
    const section = document.querySelector('[data-section-type="featured-collection-slider"]');
    if (!section) return;

    const wrapper = section.querySelector('#fcs-slides-wrapper');
    const slides = wrapper ? wrapper.querySelectorAll('.fcs-slide') : [];
    const total = slides.length;
    if (total === 0) return;

    const controls = section.querySelector('#fcs-controls');
    const prevBtn = section.querySelector('.fcs-prev');
    const nextBtn = section.querySelector('.fcs-next');
    const progressFill = section.querySelector('.fcs-progress-fill');

    const sliderEnabled = section.dataset.sliderEnabled === 'true';
    const columnsDesktop = parseInt(section.dataset.columns, 10) || 4;

    function getVisibleCount() {
      if (window.innerWidth >= 1024) return columnsDesktop;
      if (window.innerWidth >= 768) return Math.min(columnsDesktop, 3);
      if (window.innerWidth >= 480) return Math.min(columnsDesktop, 2);
      return 1;
    }

    let currentIndex = 0;
    let startX = 0;
    let isDragging = false;

    function isSliderActive() {
      if (!sliderEnabled) return false;
      const visible = getVisibleCount();
      return total > visible;
    }

    function updateSliderState() {
      const active = isSliderActive();

      if (active) {
        wrapper.classList.remove('is-static');
        controls.classList.remove('is-hidden');
        wrapper.style.flexWrap = 'nowrap';
        updateSliderPosition();
      } else {
        wrapper.classList.add('is-static');
        controls.classList.add('is-hidden');
        wrapper.style.transform = 'translateX(0px)';
        wrapper.style.flexWrap = 'wrap';
        if (progressFill) progressFill.style.width = '0%';
        prevBtn.disabled = true;
        nextBtn.disabled = true;
      }
    }

    function updateSliderPosition() {
      if (!isSliderActive()) return;

      const visible = getVisibleCount();
      const maxIndex = Math.max(0, total - visible);

      if (currentIndex > maxIndex) currentIndex = maxIndex;
      if (currentIndex < 0) currentIndex = 0;

      const slide = slides[0];
      if (!slide) return;
      const slideWidth = slide.offsetWidth;
      const gap = 20; 
      const offset = currentIndex * (slideWidth + gap);

      wrapper.style.transform = `translateX(-${offset}px)`;

      const progress = maxIndex === 0 ? 0 : (currentIndex / maxIndex) * 100;
      if (progressFill) progressFill.style.width = progress + '%';

      prevBtn.disabled = (currentIndex === 0);
      nextBtn.disabled = (currentIndex === maxIndex);

      const progressBar = section.querySelector('.fcs-progress-bar');
      if (progressBar) {
        progressBar.setAttribute('aria-valuenow', currentIndex);
        progressBar.setAttribute('aria-valuemax', maxIndex);
      }
    }

    function goTo(index) {
      if (!isSliderActive()) return;
      const visible = getVisibleCount();
      const maxIndex = Math.max(0, total - visible);
      currentIndex = Math.min(Math.max(index, 0), maxIndex);
      updateSliderPosition();
    }

    function goPrev() { goTo(currentIndex - 1); }
    function goNext() { goTo(currentIndex + 1); }

    if (prevBtn) prevBtn.addEventListener('click', goPrev);
    if (nextBtn) nextBtn.addEventListener('click', goNext);

    const container = section.querySelector('.fcs-slider-container');
    if (container) {
      container.addEventListener('touchstart', function(e) {
        if (!isSliderActive()) return;
        startX = e.touches[0].clientX;
        isDragging = true;
      }, { passive: true });

      container.addEventListener('touchmove', function(e) {
        if (!isDragging || !isSliderActive()) return;
      }, { passive: true });

      container.addEventListener('touchend', function(e) {
        if (!isDragging || !isSliderActive()) return;
        isDragging = false;
        const endX = e.changedTouches[0].clientX;
        const diff = startX - endX;
        if (Math.abs(diff) > 40) { 
          if (diff > 0) {
            goNext();
          } else {
            goPrev();
          }
        }
      }, { passive: true });
    }

    let resizeTimeout;
    window.addEventListener('resize', function() {
      clearTimeout(resizeTimeout);
      resizeTimeout = setTimeout(() => {
        const visible = getVisibleCount();
        const maxIndex = Math.max(0, total - visible);
        if (currentIndex > maxIndex) currentIndex = maxIndex;
        updateSliderState();
        if (isSliderActive()) {
          updateSliderPosition();
        }
      }, 200);
    });

    const style = document.createElement('style');
    style.textContent = `
      .fcs-slide {
        flex: 0 0 calc(${100 / columnsDesktop}% - 15px);
      }
      @media screen and (max-width: 1024px) {
        .fcs-slide { flex: 0 0 calc(33.333% - 14px); }
      }
      @media screen and (max-width: 768px) {
        .fcs-slide { flex: 0 0 calc(66.666% - 10px); }
      }
      @media screen and (max-width: 480px) {
        .fcs-slide { flex: 0 0 calc(66.666% - 10px); }
      }
      /* Override for static grid */
      .fcs-slides-wrapper.is-static .fcs-slide {
        flex: 0 0 calc(${100 / columnsDesktop}% - 15px);
      }
      @media screen and (max-width: 1024px) {
        .fcs-slides-wrapper.is-static .fcs-slide { flex: 0 0 calc(33.333% - 14px); }
      }
      @media screen and (max-width: 768px) {
        .fcs-slides-wrapper.is-static .fcs-slide { flex: 0 0 calc(50% - 10px); }
      }
      @media screen and (max-width: 480px) {
        .fcs-slides-wrapper.is-static .fcs-slide { flex: 0 0 calc(100% - 0px); }
      }
    `;
    document.head.appendChild(style);

    updateSliderState();
    if (isSliderActive()) {
      updateSliderPosition();
    }
  })();
</script>

{% schema %}
{
  "name": "Featured Slider",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading Text",
      "default": "NEW"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "Featured Collection"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to display"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Number of products to show",
      "min": 2,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on Desktop (visible slides)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
