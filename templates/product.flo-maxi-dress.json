        "custom_liquid_WLLDjK": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n  .wiw { margin-top: 24px; padding-top: 20px; border-top: 1px solid #eee; }\n  .wiw__title { text-align: center; font-size: 14px; letter-spacing: .12em; text-transform: uppercase; margin: 0 0 16px; font-weight: 500; }\n  .wiw__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }\n  .wiw__card { display: block; text-decoration: none; color: inherit; }\n  .wiw__imgwrap { width: 100%; aspect-ratio: 3/4; overflow: hidden; background: #f5f5f5; }\n  .wiw__imgwrap img { width: 100%; height: 100%; object-fit: cover; display: block; }\n  .wiw__name { margin: 10px 0 4px; font-size: 12px; letter-spacing: .08em; text-transform: uppercase; }\n  .wiw__price { margin: 0; font-size: 12px; color: #777; }\n  .wiw[hidden] { display: none; }\n</style>\n<div class=\"wiw\" id=\"wiw-{{ product.id }}\" hidden>\n  <h2 class=\"wiw__title\">Wear It With</h2>\n  <div class=\"wiw__grid\"></div>\n</div>\n<script>\n(function () {\n  var root = document.getElementById('wiw-{{ product.id }}');\n  if (!root) return;\n  var grid = root.querySelector('.wiw__grid');\n  var pid = {{ product.id | json }};\n  var limit = 2;\n  var cur = (window.Shopify && Shopify.currency && Shopify.currency.active) || 'GBP';\n  var fmt = new Intl.NumberFormat(undefined, { style: 'currency', currency: cur });\n  fetch('/recommendations/products.json?product_id=' + pid + '&intent=complementary&limit=' + limit)\n    .then(function (r) { return r.json(); })\n    .then(function (data) {\n      var items = (data && data.products) || [];\n      if (!items.length) return;\n      items.forEach(function (p) {\n        var img = p.featured_image || (p.images && p.images[0]) || '';\n        if (img) img += (img.indexOf('?') > -1 ? '&' : '?') + 'width=400';\n        var price = fmt.format((p.price || 0) / 100);\n        var a = document.createElement('a');\n        a.className = 'wiw__card';\n        a.href = p.url;\n        a.innerHTML = '<div class=\"wiw__imgwrap\">' + (img ? '<img src=\"' + img + '\" alt=\"\" loading=\"lazy\">' : '') + '</div><p class=\"wiw__name\">' + (p.title || '') + '</p><p class=\"wiw__price\">' + price + '</p>';\n        grid.appendChild(a);\n      });\n      root.hidden = false;\n    }).catch(function () {});\n})();\n</script>"
          }
        },
