 class=\"wiw__grid\"\u003e\u003c/div\u003e\n\u003c/div\u003e\n\u003cscript\u003e\n(function () {\n  var root = document.getElementById('wiw-{{ product.id }}');\n  if (!root) return;\n  var grid = root.querySelector('.wiw__grid');\n  var pid = {{ product.id | json }};\n  var limit = 2;\n  var cur = (window.Shopify \u0026\u0026 Shopify.currency \u0026\u0026 Shopify.currency.active) || 'GBP';\n  var fmt = new Intl.NumberFormat(undefined, { style: 'currency', currency: cur });\n  fetch('/recommendations/products.json?product_id=' + pid + '\u0026intent=complementary\u0026limit=' + limit)\n    .then(function (r) { return r.json(); })\n    .then(function (data) {\n      var items = (data \u0026\u0026 data.products) || [];\n      if (!items.length) return;\n      items.forEach(function (p) {\n        var img = p.featured_image || (p.images \u0026\u0026 p.images[0]) || '';\n        if (img) img += (img.indexOf('?') \u003e -1 ? '\u0026' : '?') + 'width=400';\n        var price = fmt.format((p.price || 0) / 100);\n        var a = document.createElement('a');\n        a.className = 'wiw__card';\n        a.href = p.url;\n        a.innerHTML = '\u003cdiv class=\"wiw__imgwrap\"\u003e' + (img ? '\u003cimg src=\"' + img + '\" alt=\"\" loading=\"lazy\"\u003e' : '') + '\u003c/div\u003e\u003cp class=\"wiw__name\"\u003e' + (p.title || '') + '\u003c/p\u003e\u003cp class=\"wiw__price\"\u003e' + price + '\u003c/p\u003e';\n        grid.appendChild(a);\n      });\n      root.hidden = false;\n    }).catch(function () {});\n})();\n\u003c/script\u003e"},"type":"custom_liquid"},"da131bd9-78d4-4a8e-9adf-df14674d27cd":{"disabled":true,"settings":{"heading":"","heading_size":17,"icon_size":24,"padding_bottom":8,"padding_top":12,"text":"\u003cp\u003eThis layout can be adjusted.\u003c/p\u003e","text_size":16},"type":"feature"},"f34ad5c4-50a9-4a95-a561-d8c51d1b76dd":{"settings":{"content":"\u003cp\u003eWe accept returns within 30 days of receiving your order. For some countries it is 14 days. Please c